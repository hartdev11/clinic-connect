# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง (ดู docs/FIREBASE-SETUP.md)

# Session JWT — อย่างน้อย 32 ตัวอักษร
SESSION_SECRET=your-session-secret-at-least-32-chars

# Firebase — เลือกอย่างใดอย่างหนึ่ง:

# วิธีที่ 1 (แนะนำ): ใส่ path ไปยังไฟล์ JSON ที่ดาวน์โหลดจาก Firebase
# วางไฟล์ JSON ในโปรเจกต์ แล้วตั้งชื่อเช่น firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# วิธีที่ 2: ใส่ค่าจากไฟล์ JSON แยกบรรทัด
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Phase 7: LINE Webhook + Chat Agent (ดู docs/LINE-WEBHOOK-SETUP.md)
# LINE_CHANNEL_SECRET=xxxx
# LINE_CHANNEL_ACCESS_TOKEN=xxxx
# OPENAI_API_KEY=sk-xxxx   # ChatGPT (GPT-4o-mini)
# GEMINI_API_KEY=xxxx      # Gemini (ทดลองฟรีได้ที่ https://aistudio.google.com/apikey)
# CHAT_PROVIDER=auto       # openai | gemini | auto (auto = ลอง OpenAI ก่อน ถ้าไม่ได้ลอง Gemini)
# CHAT_USE_PIPELINE=true   # ใช้ multi-agent flow (Intent → Safety → Knowledge → Compose); ถ้าไม่ใส่ใช้ chat agent เดิม
# USE_CORE_BRAIN=true      # Phase 22: ใช้ CoreBrain (Gemini) แทน Role Manager; ตั้ง GEMINI_API_KEY แล้วใช้ได้อัตโนมัติ

# E3.1 — Pinecone (Vector DB สำหรับ knowledge)
# PINECONE_API_KEY=xxxx
# PINECONE_INDEX_NAME=clinic-knowledge
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1

# E7 — Stripe Payment Gateway
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PROFESSIONAL=price_...
# STRIPE_PRICE_MULTI_BRANCH=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ─── Firebase Client (Realtime Listeners — Customers & Chat) ─────────
# ดึงจาก Firebase Console → Project Settings → Your apps → Add app → Web
# ถ้าไม่ใส่ ระบบจะใช้ polling แทน
# NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
# NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc...

# ─── Phase 7: Handoff Reminders (BullMQ) ───────────────────────────
# ใช้ส่งอีเมลเตือนเมื่อ handoff ค้างเกิน 2/5 นาที
# REDIS_URL=redis://localhost:6379
# รัน worker: npm run worker:handoff-reminder
#
# ─── Phase 11: Handoff Rate Limit (cooldown 10min + 3/day) ─────────
# ใช้ REDIS_URL เดียวกัน — ถ้าไม่มีจะไม่บังคับ rate limit

# ─── Enterprise AI Platform Hardening (Phase 0 — optional) ──────────
# Redis + LLM semaphore/budget (not wired to production yet)
# REDIS_URL=redis://localhost:6379
# GLOBAL_LLM_MAX=10
# PER_ORG_LLM_MAX=3
# LLM_SLOT_TTL_SEC=120

# ─── Phase 6: Retrain Monitor ───────────────────────────────────────
# อีเมล super_admin เพื่อรับแจ้งเมื่อพร้อม Retrain โมเดล
# RETRAIN_NOTIFY_EMAIL=admin@your-domain.com

# ─── LINE Multi-tenant + Webhook URL ─────────────────────────────────
# โดเมนของเว็บ — ใช้สร้าง Webhook URL ให้คลินิก (Settings → LINE Connection)
# Local: http://localhost:3000
# Vercel: https://your-project.vercel.app (หรือ VERCEL_URL มีให้อัตโนมัติ)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
